{
  "name": "getpatter",
  "version": "0.6.5",
  "description": "Open-source voice AI SDK — connect any AI agent to real phone calls in 4 lines of code",
  "license": "MIT",
  "author": {
    "name": "PatterAI",
    "email": "hello@getpatter.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PatterAI/Patter.git",
    "directory": "libraries/typescript"
  },
  "homepage": "https://www.getpatter.com",
  "bugs": {
    "url": "https://github.com/PatterAI/Patter/issues"
  },
  "keywords": [
    "voice",
    "ai",
    "voice-ai",
    "phone",
    "telephony",
    "speech",
    "tts",
    "stt",
    "twilio",
    "telnyx",
    "plivo",
    "openai",
    "elevenlabs",
    "llm",
    "agent",
    "ai-agent",
    "conversational-ai",
    "realtime",
    "call",
    "ivr",
    "chatbot"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "getpatter": "dist/cli.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src/resources/audio/NOTICE",
    "src/resources/audio/*.ogg",
    "src/dashboard/ui.html"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts && tsup src/cli.ts --format cjs --no-dts && node -e \"const fs=require('fs');fs.cpSync('src/resources','dist/resources',{recursive:true,filter:p=>!p.endsWith('.ts')});fs.mkdirSync('dist/dashboard',{recursive:true});fs.copyFileSync('src/dashboard/ui.html','dist/dashboard/ui.html')\"",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cloudflared": "^0.7.1",
    "node-cron": "^4.0.0",
    "onnxruntime-node": "~1.18.0"
  },
  "peerDependencies": {
    "@google/genai": "^0.3.0"
  },
  "peerDependenciesMeta": {
    "@google/genai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
