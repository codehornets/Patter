# ============================================================
# Patter Python SDK — Environment Variables
# ============================================================
# Copy:  cp libraries/python/.env.example libraries/python/.env
# Pick the providers you actually use; uncomment and fill in.
# Every entry is optional unless explicitly required by the
# integration you wire up.

# ------------------------------------------------------------
# Telephony carrier (pick at least one)
# ------------------------------------------------------------
# Twilio — TwiML over WS, mu-law 8 kHz
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Telnyx — Call Control + Streaming, PCM 16 kHz, Ed25519 signature
# TELNYX_API_KEY=KEY...
# TELNYX_CONNECTION_ID=
# TELNYX_PUBLIC_KEY=
# TELNYX_PHONE_NUMBER=+1xxxxxxxxxx

# ------------------------------------------------------------
# Voice mode — OpenAI Realtime (default, all-in-one)
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# ------------------------------------------------------------
# LLM providers (pipeline mode)
# ------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# CEREBRAS_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Vertex AI (alternative to GEMINI_API_KEY)
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# ------------------------------------------------------------
# STT providers
# ------------------------------------------------------------
# DEEPGRAM_API_KEY=
# ASSEMBLYAI_API_KEY=
# SPEECHMATICS_API_KEY=
# SONIOX_API_KEY=
# CARTESIA_API_KEY=

# ------------------------------------------------------------
# TTS providers
# ------------------------------------------------------------
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=
# LMNT_API_KEY=
# RIME_API_KEY=

# ------------------------------------------------------------
# Patter runtime tunables
# ------------------------------------------------------------
# Where call logs (transcript, metrics, audit) are written.
# Defaults to platform-appropriate cache dir.
# PATTER_LOG_DIR=

# Days of call logs retained on disk (default: 14)
# PATTER_LOG_RETENTION_DAYS=14

# Redact phone numbers in logs to last 4 digits (default: true)
# PATTER_LOG_REDACT_PHONE=true

# TTS playback tail buffer (ms) before clearing barge-in arming.
# Twilio buffers ~1500 ms of audio; raising this keeps barge-in
# armed while the caller is still hearing the agent.
# PATTER_TTS_TAIL_GRACE_MS=1500
